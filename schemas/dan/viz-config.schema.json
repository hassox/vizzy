{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resources.rusl.com/resources/dan/schemas/viz-config",
  "title": "VizConfig",
  "description": "Client-side Vizzy configuration. One schema covers a single run (dashboard preset), named source bookmarks, and the local library envelope. Not an event wire format — only geo-event rides the WebSocket.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources", "presets"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Library document version."
    },
    "sources": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/source" },
      "description": "Named event feed bookmarks."
    },
    "presets": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/preset" },
      "description": "Saved full run configurations."
    },
    "activePresetId": {
      "type": ["string", "null"],
      "default": null,
      "description": "Last-applied preset id, if any."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "url"],
      "description": "Named bookmark for an event feed endpoint.",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable client id (UUID recommended)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "description": "Human label in the source picker."
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "WebSocket URL (ws:// or wss://). Clients may normalize host:port and http(s) before save."
        },
        "notes": {
          "type": "string",
          "maxLength": 400,
          "description": "Optional free-text (env, owner, caveats)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "sourceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "description": "How a preset connects to an event feed: ad-hoc URL, one saved source, or a cycle through saved sources.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["url", "saved", "cycle"]
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Ad-hoc WebSocket URL when mode=url."
        },
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "description": "Library source id when mode=saved."
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1 },
          "description": "Ordered library source ids when mode=cycle."
        },
        "cycleIntervalSec": {
          "type": "number",
          "minimum": 5,
          "maximum": 3600,
          "default": 60,
          "description": "Seconds per source when mode=cycle."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "url" } },
            "required": ["mode"]
          },
          "then": { "required": ["url"] }
        },
        {
          "if": {
            "properties": { "mode": { "const": "saved" } },
            "required": ["mode"]
          },
          "then": { "required": ["sourceId"] }
        },
        {
          "if": {
            "properties": { "mode": { "const": "cycle" } },
            "required": ["mode"]
          },
          "then": { "required": ["sourceIds"] }
        }
      ]
    },
    "preset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source", "title"],
      "description": "Full configuration for one viz run / wall story. The wall title is the preset label — no separate name field.",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "integer",
          "const": 1,
          "description": "Preset document version. Bump when breaking fields change."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "Wall masthead title and preset label in the picker."
        },
        "description": {
          "type": "string",
          "maxLength": 400,
          "default": "",
          "description": "Wall masthead subtitle / about."
        },
        "theme": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "default": "ember",
          "description": "Theme id. Unknown ids fall back to the client default."
        },
        "maxConcurrent": {
          "type": "integer",
          "minimum": 10,
          "maximum": 500,
          "default": 200,
          "description": "Max live arcs — relative top-N by priority."
        },
        "audio": {
          "type": "boolean",
          "default": false
        },
        "spin": {
          "type": "boolean",
          "default": true,
          "description": "Auto-rotate when true; pin view when false."
        },
        "playbook": {
          "type": ["string", "null"],
          "maxLength": 64,
          "default": null,
          "description": "Optional generator scenario id to start with."
        },
        "source": {
          "$ref": "#/$defs/sourceBinding"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
